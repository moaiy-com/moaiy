          "stringUnit": {
            "state": "translated",
            "value": "अतिरिक्त सुरक्षा प्रतिबंधों के साथ पुराने बैकअप से कुंजियाँ पुनर्स्थापित की गईं।"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تمت استعادة المفاتيح من نسخة احتياطية قديمة مع قيود أمان إضافية."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les clés ont été restaurées à partir d'une sauvegarde héritée avec des restrictions de sécurité supplémentaires."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die Schlüssel wurden aus einem alten Backup mit zusätzlichen Sicherheitseinschränkungen wiederhergestellt."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "キーは、安全上の制限が追加されたレガシー バックアップから復元されました。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "추가 안전 제한 사항을 적용하여 레거시 백업에서 키를 복원했습니다."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Ключи были восстановлены из устаревшей резервной копии с дополнительными ограничениями безопасности."
          }
        }
      }
    },
