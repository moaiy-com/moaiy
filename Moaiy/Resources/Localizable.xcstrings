    "tutorial_create_first_key_content" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "افتح إدارة المفاتيح، وانقر على إنشاء مفتاح، وأدخل اسمك وبريدك الإلكتروني، ثم قم بتعيين عبارة مرور."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Öffnen Sie die Schlüsselverwaltung, klicken Sie auf Schlüssel erstellen, geben Sie Ihren Namen und Ihre E-Mail-Adresse ein und legen Sie dann eine Passphrase fest."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Open Key Management, click Create Key, fill in your name and email, then set a passphrase."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Abra Administración de claves, haga clic en Crear clave, complete su nombre y correo electrónico, luego establezca una frase de contraseña."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ouvrez Key Management, cliquez sur Créer une clé, indiquez votre nom et votre adresse e-mail, puis définissez une phrase secrète."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "कुंजी प्रबंधन खोलें, कुंजी बनाएं पर क्लिक करें, अपना नाम और ईमेल भरें, फिर पासफ़्रेज़ सेट करें।"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "「キー管理」を開き、「キーの作成」をクリックし、名前と電子メールを入力して、パスフレーズを設定します。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "키 관리를 열고 키 생성을 클릭한 후 이름과 이메일을 입력하고 암호를 설정하세요."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Abra o Gerenciamento de chaves, clique em Criar chave, preencha seu nome e e-mail e defina uma senha longa."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Откройте «Управление ключами», нажмите «Создать ключ», введите свое имя и адрес электронной почты, затем установите парольную фразу."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "打开密钥管理，点击创建密钥，填写姓名和邮箱，然后设置口令。"
          }
        }
      }
    },
