    "migration_system_keyring_message" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "لقد عثرنا على منزل GnuPG موجود على جهاز Mac هذا. يمكنك استيراد مفاتيحك الحالية إلى حلقة المفاتيح المُدارة من Moaiy."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wir haben auf diesem Mac ein vorhandenes GnuPG-Heim gefunden. Sie können Ihre vorhandenen Schlüssel in den verwalteten Schlüsselbund von Moaiy importieren."
          }
        },
        "en" : {
          "stringUnit" : {
