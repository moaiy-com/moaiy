    "sign_info_text" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "التوقيع على المفتاح يعني أنك تقر بأنه ينتمي إلى الشخص المطالب به. فقط مفاتيح التوقيع التي قمت بالتحقق منها."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Durch die Signatur eines Schlüssels bestätigen Sie, dass er der beanspruchten Person gehört. Signieren Sie nur Schlüssel, die Sie verifiziert haben."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Signing a key means you certify that it belongs to the person claimed. Only sign keys you have verified."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Firmar una clave significa que usted certifica que pertenece a la persona reclamada. Firme únicamente las claves que haya verificado."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Signer une clé signifie que vous certifiez qu'elle appartient à la personne réclamée. Signez uniquement les clés que vous avez vérifiées."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "किसी कुंजी पर हस्ताक्षर करने का मतलब है कि आप प्रमाणित करते हैं कि यह उस व्यक्ति की है जिस पर दावा किया गया है। केवल साइन कुंजियाँ जिन्हें आपने सत्यापित किया है।"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "キーに署名するということは、そのキーが要求された人物のものであることを証明することを意味します。検証したキーのみに署名してください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "키에 서명한다는 것은 해당 키가 청구된 사람의 소유임을 인증한다는 의미입니다. 본인이 확인한 서명 키만 사용하세요."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Assinar uma chave significa que você certifica que ela pertence à pessoa reivindicada. Assine apenas as chaves que você verificou."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Подписание ключа означает, что вы подтверждаете, что он принадлежит заявленному лицу. Подписывайте только те ключи, которые вы проверили."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "签名密钥意味着您证明它属于声称的所有者。仅签名您已验证的密钥。"
          }
        }
      }
    },
