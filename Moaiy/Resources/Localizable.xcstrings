    "tutorial_import_keys_content" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "استخدم مفتاح الاستيراد لإضافة الملفات الرئيسية. يكتشف Moaiy المفاتيح العامة والخاصة تلقائيًا."
