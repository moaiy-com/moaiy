    "verify_signature_error_bad_signature": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Verification was not successful. The original file may have been modified."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "验证不成功，原文件可能已经被修改。"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La verificación no fue exitosa. Es posible que el archivo original haya sido modificado."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "A verificação não foi bem-sucedida. O arquivo original pode ter sido modificado."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "सत्यापन सफल नहीं हुआ. मूल फ़ाइल को संशोधित किया गया हो सकता है."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "لم تكن عملية التحقق ناجحة. ربما تم تعديل الملف الأصلي."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La vérification n'a pas réussi. Le fichier original a peut-être été modifié."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die Verifizierung war nicht erfolgreich. Die Originaldatei wurde möglicherweise geändert."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "検証が成功しませんでした。元のファイルが変更されている可能性があります。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "확인에 실패했습니다. 원본 파일이 수정되었을 수 있습니다."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Проверка не прошла успешно. Исходный файл мог быть изменен."
          }
        }
      }
    },
