    "no_keys_available": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "No keys available. Please import or create keys first."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "没有可用密钥。请先导入或创建密钥。"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No hay llaves disponibles. Primero importe o cree claves."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Nenhuma chave disponível. Importe ou crie chaves primeiro."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "कोई चाबियाँ उपलब्ध नहीं. कृपया पहले कुंजियाँ आयात करें या बनाएँ।"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "لا توجد مفاتيح متاحة. الرجاء استيراد المفاتيح أو إنشائها أولاً."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Aucune clé disponible. Veuillez d'abord importer ou créer des clés."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Keine Schlüssel vorhanden. Bitte importieren oder erstellen Sie zuerst Schlüssel."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "利用可能なキーがありません。最初にキーをインポートまたは作成してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "사용 가능한 열쇠가 없습니다. 먼저 키를 가져오거나 생성하세요."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Ключей нет. Сначала импортируйте или создайте ключи."
          }
        }
      }
    },
