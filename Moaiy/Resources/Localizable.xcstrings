    "verify_signature_error_missing_original": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "We couldn't find the original file for this signature. Keep both files in the same folder and try again."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "找不到与该签名对应的原文件。请将签名文件和原文件放在同一文件夹后重试。"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No pudimos encontrar el archivo original de esta firma. Mantenga ambos archivos en la misma carpeta y vuelva a intentarlo."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Não foi possível encontrar o arquivo original desta assinatura. Mantenha os dois arquivos na mesma pasta e tente novamente."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "हमें इस हस्ताक्षर की मूल फ़ाइल नहीं मिल सकी. दोनों फ़ाइलों को एक ही फ़ोल्डर में रखें और पुनः प्रयास करें।"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "لم نتمكن من العثور على الملف الأصلي لهذا التوقيع. احتفظ بالملفين في نفس المجلد وحاول مرة أخرى."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Nous n'avons pas pu trouver le fichier original de cette signature. Conservez les deux fichiers dans le même dossier et réessayez."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wir konnten die Originaldatei für diese Signatur nicht finden. Bewahren Sie beide Dateien im selben Ordner auf und versuchen Sie es erneut."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "この署名の元のファイルが見つかりませんでした。両方のファイルを同じフォルダーに保存して、再試行してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 서명의 원본 파일을 찾을 수 없습니다. 두 파일을 모두 같은 폴더에 보관하고 다시 시도하세요."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Нам не удалось найти исходный файл этой подписи. Сохраните оба файла в одной папке и повторите попытку."
          }
        }
      }
    },
    "verify_signature_error_missing_public_key": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "We can't verify this signature yet. Import the sender's public key and try again."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "暂时无法验证该签名。请先导入发送者的公钥后重试。"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No podemos verificar esta firma todavía. Importe la clave pública del remitente y vuelva a intentarlo."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Ainda não podemos verificar esta assinatura. Importe a chave pública do remetente e tente novamente."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "हम अभी तक इस हस्ताक्षर को सत्यापित नहीं कर सकते. प्रेषक की सार्वजनिक कुंजी आयात करें और पुनः प्रयास करें।"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "لا يمكننا التحقق من هذا التوقيع بعد. قم باستيراد المفتاح العام للمرسل وحاول مرة أخرى."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Nous ne pouvons pas encore vérifier cette signature. Importez la clé publique de l'expéditeur et réessayez."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wir können diese Signatur noch nicht überprüfen. Importieren Sie den öffentlichen Schlüssel des Absenders und versuchen Sie es erneut."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "この署名はまだ検証できません。送信者の公開キーをインポートして、再試行してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "아직 이 서명을 확인할 수 없습니다. 보낸 사람의 공개 키를 가져온 후 다시 시도하세요."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Мы пока не можем проверить эту подпись. Импортируйте открытый ключ отправителя и повторите попытку."
          }
        }
      }
    },
