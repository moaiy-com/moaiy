    "tutorial_keyserver_content" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "قم بتحميل مفتاحك العام إلى Keys.openpgp.org حتى يتمكن الآخرون من العثور عليك وتشفيره لك."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Laden Sie Ihren öffentlichen Schlüssel auf keys.openpgp.org hoch, damit andere Sie finden und verschlüsseln können."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Upload your public key to keys.openpgp.org so others can find and encrypt to you."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cargue su clave pública en claves.openpgp.org para que otros puedan encontrarla y cifrarla."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Téléchargez votre clé publique sur keys.openpgp.org afin que d'autres puissent vous trouver et vous chiffrer."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "अपनी सार्वजनिक कुंजी को key.openpgp.org पर अपलोड करें ताकि अन्य लोग आपको ढूंढ सकें और एन्क्रिप्ट कर सकें।"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "公開鍵をkeys.openpgp.orgにアップロードすると、他の人があなたを見つけて暗号化できるようになります。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "다른 사람들이 귀하를 찾아 암호화할 수 있도록 공개 키를 key.openpgp.org에 업로드하세요."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Carregue sua chave pública em keys.openpgp.org para que outras pessoas possam encontrar e criptografar para você."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Загрузите свой открытый ключ на сайтkeys.openpgp.org, чтобы другие могли его найти и зашифровать."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "将你的公钥上传到 keys.openpgp.org，方便他人检索并加密给你。"
          }
        }
      }
    },
    "tutorial_public_private_keys" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "المفاتيح العامة مقابل المفاتيح الخاصة"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Öffentliche vs. private Schlüssel"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Public vs Private Keys"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Claves públicas versus privadas"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Clés publiques ou privées"
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "सार्वजनिक बनाम निजी कुंजी"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "公開キーと秘密キー"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "공개 키와 개인 키"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Chaves públicas versus chaves privadas"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Открытые и закрытые ключи"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "公钥与私钥"
          }
        }
      }
    },
    "tutorial_public_private_keys_content" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تشفير المفاتيح العامة أو التحقق منها. فك تشفير المفاتيح الخاصة أو التوقيع عليها. لا تشارك مفتاحك الخاص أبدًا."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Öffentliche Schlüssel verschlüsseln oder verifizieren. Private Schlüssel entschlüsseln oder signieren. Geben Sie niemals Ihren privaten Schlüssel weiter."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Public keys encrypt or verify. Private keys decrypt or sign. Never share your private key."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Las claves públicas cifran o verifican. Las claves privadas se descifran o firman. Nunca compartas tu clave privada."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les clés publiques chiffrent ou vérifient. Les clés privées décryptent ou signent. Ne partagez jamais votre clé privée."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "सार्वजनिक कुंजियाँ एन्क्रिप्ट या सत्यापित करें। निजी कुंजियाँ डिक्रिप्ट या हस्ताक्षर करती हैं। अपनी निजी कुंजी कभी साझा न करें."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "公開鍵は暗号化または検証します。秘密キーは復号化または署名します。秘密キーを決して共有しないでください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "공개 키는 암호화하거나 확인합니다. 개인 키는 암호를 해독하거나 서명합니다. 개인 키를 절대 공유하지 마세요."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "As chaves públicas criptografam ou verificam. As chaves privadas são descriptografadas ou assinadas. Nunca compartilhe sua chave privada."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Открытые ключи шифруют или проверяют. Закрытые ключи расшифровывают или подписывают. Никогда не делитесь своим секретным ключом."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "公钥用于加密或验证，私钥用于解密或签名。请勿分享你的私钥。"
          }
        }
      }
    },
