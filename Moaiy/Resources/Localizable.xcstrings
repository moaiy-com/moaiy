    "tutorial_export_keys_content" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "استخدم الإجراءات الرئيسية لتصدير المفاتيح العامة للمشاركة أو المفاتيح الخاصة للنسخ الاحتياطي."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Verwenden Sie Schlüsselaktionen, um öffentliche Schlüssel zur Freigabe oder private Schlüssel zur Sicherung zu exportieren."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Use key actions to export public keys for sharing or private keys for backup."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Utilice acciones clave para exportar claves públicas para compartir o claves privadas para realizar copias de seguridad."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Utilisez des actions clés pour exporter des clés publiques pour le partage ou des clés privées pour la sauvegarde."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "साझा करने के लिए सार्वजनिक कुंजियाँ या बैकअप के लिए निजी कुंजियाँ निर्यात करने के लिए मुख्य क्रियाओं का उपयोग करें।"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "キー アクションを使用して、共有用の公開キーまたはバックアップ用の秘密キーをエクスポートします。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "키 작업을 사용하여 공유용 공개 키 또는 백업용 개인 키를 내보냅니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Use ações-chave para exportar chaves públicas para compartilhamento ou chaves privadas para backup."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Используйте ключевые действия для экспорта открытых ключей для совместного использования или закрытых ключей для резервного копирования."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "使用密钥操作导出公钥用于分享，或导出私钥用于备份。"
          }
        }
      }
    },
