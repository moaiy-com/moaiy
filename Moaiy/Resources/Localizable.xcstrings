    "yubikey_import_info_hint" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "إذا فشل استيراد عنوان URL للبطاقة أو كان مفقودًا، فاستورد المفتاح العام يدويًا (من ملف أو من خادم المفاتيح)."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wenn der Import der Karten-URL fehlschlägt oder fehlt, importieren Sie den öffentlichen Schlüssel manuell (aus Datei oder vom Schlüsselserver)."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "If card URL import fails or is missing, import the public key manually (From File or From Keyserver)."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Si la importación de la URL de la tarjeta falla o falta, importe la clave pública manualmente (desde archivo o desde servidor de claves)."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Si l'importation de l'URL de la carte échoue ou est manquante, importez la clé publique manuellement (à partir d'un fichier ou à partir d'un serveur de clés)."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "यदि कार्ड यूआरएल आयात विफल हो जाता है या गायब है, तो सार्वजनिक कुंजी को मैन्युअल रूप से आयात करें (फ़ाइल से या कीसर्वर से)।"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "カード URL のインポートが失敗するか、カード URL が見つからない場合は、公開キーを手動でインポートします (ファイルからまたはキーサーバーから)。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "카드 URL 가져오기에 실패하거나 누락된 경우 공개 키를 수동으로 가져오세요(파일에서 또는 키서버에서)."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Se a importação do URL do cartão falhar ou estiver faltando, importe a chave pública manualmente (Do arquivo ou Do servidor de chaves)."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Если импорт URL-адреса карты не удался или отсутствует, импортируйте открытый ключ вручную (из файла или с сервера ключей)."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "如果卡内 URL 导入失败或未配置，请手动导入公钥（From File 或 From Keyserver）。"
          }
        }
      }
    },
    "yubikey_import_manual_pubkey_required" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "عنوان URL للمفتاح العام لبطاقة SmartCard مفقود أو فشل التنزيل التلقائي. الرجاء استيراد المفتاح العام يدويًا (من ملف أو من خادم المفاتيح)؛ سيظهر مفتاح SmartCard في القائمة بعد استيراد المفتاح العام."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Die URL Ihres öffentlichen SmartCard-Schlüssels fehlt oder der automatische Download ist fehlgeschlagen. Bitte importieren Sie den öffentlichen Schlüssel manuell (aus Datei oder vom Schlüsselserver). Der SmartCard-Schlüssel erscheint in der Liste, nachdem der öffentliche Schlüssel importiert wurde."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Your SmartCard public key URL is missing or auto-download failed. Please import the public key manually (From File or From Keyserver); the SmartCard key will appear in the list after the public key is imported."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Falta la URL de la clave pública de su SmartCard o falló la descarga automática. Importe la clave pública manualmente (desde archivo o desde servidor de claves); la clave SmartCard aparecerá en la lista después de importar la clave pública."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "L'URL de votre clé publique SmartCard est manquante ou le téléchargement automatique a échoué. Veuillez importer la clé publique manuellement (à partir d'un fichier ou à partir d'un serveur de clés) ; la clé SmartCard apparaîtra dans la liste après l'importation de la clé publique."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "आपका स्मार्टकार्ड सार्वजनिक कुंजी यूआरएल गुम है या ऑटो-डाउनलोड विफल रहा है। कृपया सार्वजनिक कुंजी को मैन्युअल रूप से आयात करें (फ़ाइल से या कीसर्वर से); सार्वजनिक कुंजी आयात होने के बाद स्मार्टकार्ड कुंजी सूची में दिखाई देगी।"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "SmartCard 公開キー URL が見つからないか、自動ダウンロードに失敗しました。公開キーを手動でインポートしてください (ファイルからまたはキーサーバーから)。公開キーがインポートされた後、SmartCard キーがリストに表示されます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "스마트카드 공개 키 URL이 누락되었거나 자동 다운로드에 실패했습니다. 공개 키를 수동으로 가져오십시오(파일에서 또는 키 서버에서). 공개 키를 가져온 후 SmartCard 키가 목록에 나타납니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O URL da chave pública do seu SmartCard está faltando ou o download automático falhou. Importe a chave pública manualmente (do arquivo ou do servidor de chaves); a chave do SmartCard aparecerá na lista após a importação da chave pública."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "URL-адрес открытого ключа вашей смарт-карты отсутствует или не удалось выполнить автоматическую загрузку. Пожалуйста, импортируйте открытый ключ вручную (из файла или с сервера ключей); Ключ смарт-карты появится в списке после импорта открытого ключа."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "您的 SmartCard pub key URL 未定义或自动下载失败。请手动导入 pub key（From File 或 From Keyserver）后，SmartCard key 才会显示在列表中。"
          }
        }
      }
    },
