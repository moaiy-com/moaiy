        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Verwenden Sie „Schlüssel importieren“, um Schlüsseldateien hinzuzufügen. Moaiy erkennt öffentliche und private Schlüssel automatisch."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Use Import Key to add key files. Moaiy detects public and private keys automatically."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Utilice Importar clave para agregar archivos clave. Moaiy detecta claves públicas y privadas automáticamente."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Utilisez Import Key pour ajouter des fichiers clés. Moaiy détecte automatiquement les clés publiques et privées."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "मुख्य फ़ाइलें जोड़ने के लिए आयात कुंजी का उपयोग करें। Moaiy सार्वजनिक और निजी कुंजियों का स्वचालित रूप से पता लगाता है।"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Import Key を使用してキー ファイルを追加します。 Moaiy は公開鍵と秘密鍵を自動的に検出します。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "키 가져오기를 사용하여 키 파일을 추가합니다. Moaiy는 공개 키와 개인 키를 자동으로 감지합니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Use Importar chave para adicionar arquivos-chave. Moaiy detecta chaves públicas e privadas automaticamente."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Используйте «Импортировать ключ», чтобы добавить файлы ключей. Moaiy автоматически определяет открытые и закрытые ключи."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "使用导入密钥添加密钥文件。Moaiy 会自动识别公钥和私钥。"
          }
        }
      }
    },
