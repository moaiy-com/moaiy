    "subkey_empty_state": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "No subkeys yet. Add one to separate encryption/signing usage."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "暂无子密钥。可添加子密钥以分离加密与签名用途。"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Aún no hay subclaves. Agrega una para separar cifrado y firma."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Ainda não há subchaves. Adicione uma para separar criptografia e assinatura."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "अभी कोई उप-कुंजी नहीं है। एन्क्रिप्शन और साइनिंग को अलग करने के लिए एक जोड़ें।"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "لا توجد مفاتيح فرعية بعد. أضف مفتاحًا لفصل استخدام التشفير والتوقيع."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Aucune sous-clé pour le moment. Ajoutez-en une pour séparer chiffrement et signature."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Noch keine Unterschlüssel. Fügen Sie einen hinzu, um Verschlüsselung und Signatur zu trennen."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "サブキーがありません。暗号化用と署名用を分けるために追加してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "하위 키가 없습니다. 암호화와 서명 용도를 분리하려면 추가하세요."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Подключей пока нет. Добавьте подключ, чтобы разделить шифрование и подпись."
          }
        }
      }
    },
