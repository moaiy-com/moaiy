    "tutorial_trust_management_content": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Set owner trust levels to control how much you trust other users' keys."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "通过设置拥有者信任级别，控制你对其他用户密钥的信任程度。"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Establezca niveles de confianza del propietario para controlar cuánto confía en las claves de otros usuarios."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Defina níveis de confiança do proprietário para controlar o quanto você confia nas chaves de outros usuários."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "आप अन्य उपयोगकर्ताओं की कुंजियों पर कितना भरोसा करते हैं, इसे नियंत्रित करने के लिए स्वामी विश्वास स्तर सेट करें।"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "قم بتعيين مستويات ثقة المالك للتحكم في مدى ثقتك في مفاتيح المستخدمين الآخرين."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Définissez les niveaux de confiance du propriétaire pour contrôler le degré de confiance que vous accordez aux clés des autres utilisateurs."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Legen Sie Eigentümervertrauensstufen fest, um zu steuern, wie sehr Sie den Schlüsseln anderer Benutzer vertrauen."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "所有者の信頼レベルを設定して、他のユーザーのキーをどの程度信頼するかを制御します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "다른 사용자의 키를 얼마나 신뢰하는지 제어하려면 소유자 신뢰 수준을 설정하세요."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Установите уровни доверия владельца, чтобы контролировать, насколько вы доверяете ключам других пользователей."
          }
        }
      }
    },
    "tutorial_what_is_gpg": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "What Is GPG?"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
