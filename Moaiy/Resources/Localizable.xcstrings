        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Moderno y eficiente, tamaño de clave más pequeño con la misma seguridad"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Moderno e eficiente, tamanho de chave menor com a mesma segurança"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "आधुनिक और कुशल, समान सुरक्षा के साथ छोटी कुंजी का आकार"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
