    "upload_success_verification_hint": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You may receive a verification email from the keyserver. Please check your inbox to finish publishing."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "密钥服务器可能会发送验证邮件，请检查收件箱并按提示完成发布。"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Es posible que reciba un correo electrónico de verificación del servidor de claves. Por favor revisa tu bandeja de entrada para terminar de publicar."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Você pode receber um e-mail de verificação do servidor de chaves. Verifique sua caixa de entrada para finalizar a publicação."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "आपको कीसर्वर से एक सत्यापन ईमेल प्राप्त हो सकता है। प्रकाशन समाप्त करने के लिए कृपया अपना इनबॉक्स जांचें।"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "قد تتلقى رسالة تحقق عبر البريد الإلكتروني من خادم المفاتيح. يرجى التحقق من صندوق الوارد الخاص بك لإنهاء النشر."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vous pouvez recevoir un e-mail de vérification du serveur de clés. Veuillez vérifier votre boîte de réception pour terminer la publication."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Möglicherweise erhalten Sie vom Schlüsselserver eine Bestätigungs-E-Mail. Bitte überprüfen Sie Ihren Posteingang, um die Veröffentlichung abzuschließen."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "キーサーバーから確認メールを受信する場合があります。公開を完了するには受信箱を確認してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "키서버로부터 확인 이메일을 받을 수 있습니다. 게시를 완료하려면 받은편지함을 확인하세요."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Вы можете получить электронное письмо с подтверждением от сервера ключей. Пожалуйста, проверьте свой почтовый ящик, чтобы завершить публикацию."
          }
        }
      }
    },
    "upload_to_keyserver_description": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Upload your public key to a keyserver so others can find and import it"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "将公钥上传到密钥服务器，以便他人查找和导入"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Cargue su clave pública a un servidor de claves para que otros puedan encontrarla e importarla."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Carregue sua chave pública em um servidor de chaves para que outras pessoas possam encontrá-la e importá-la"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "अपनी सार्वजनिक कुंजी को कीसर्वर पर अपलोड करें ताकि अन्य लोग इसे ढूंढ सकें और आयात कर सकें"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "قم بتحميل مفتاحك العام إلى خادم المفاتيح حتى يتمكن الآخرون من العثور عليه واستيراده"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Téléchargez votre clé publique sur un serveur de clés afin que d'autres puissent la trouver et l'importer"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Laden Sie Ihren öffentlichen Schlüssel auf einen Schlüsselserver hoch, damit andere ihn finden und importieren können"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "公開鍵をキーサーバーにアップロードすると、他の人が公開鍵を見つけてインポートできるようになります。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "다른 사람이 찾아서 가져올 수 있도록 공개 키를 키서버에 업로드하세요."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Загрузите свой открытый ключ на сервер ключей, чтобы другие могли его найти и импортировать."
          }
        }
      }
    },
