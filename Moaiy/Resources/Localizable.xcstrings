    "key_type_rsa2048_description" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "أسرع من RSA-4096، ولا يزال آمنًا لمعظم حالات الاستخدام"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Schneller als RSA-4096, dennoch sicher für die meisten Anwendungsfälle"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Faster than RSA-4096, still secure for most use cases"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Más rápido que RSA-4096, aún seguro para la mayoría de los casos de uso"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Plus rapide que RSA-4096, toujours sécurisé pour la plupart des cas d'utilisation"
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "RSA-4096 से तेज़, अधिकांश उपयोग के मामलों के लिए अभी भी सुरक्षित है"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "RSA-4096 よりも高速で、ほとんどのユースケースで安全です"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "RSA-4096보다 빠르지만 대부분의 사용 사례에서 여전히 안전합니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mais rápido que o RSA-4096, ainda seguro para a maioria dos casos de uso"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Быстрее, чем RSA-4096, но по-прежнему безопасно для большинства случаев использования."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "比 RSA-4096 更快，对大多数用例仍然安全"
          }
        }
      }
    },
