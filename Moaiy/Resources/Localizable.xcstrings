        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "一部の秘密キーがインポートされませんでした。インポートを再試行し、キーが利用可能であることを確認します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "일부 비밀 키를 가져오지 못했습니다. 가져오기를 다시 시도하고 키 가용성을 확인하세요."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Некоторые секретные ключи не были импортированы. Повторите попытку импорта и проверьте доступность ключа."
          }
        }
      }
    },
    "migration_system_keyring_message": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "We found an existing GnuPG home on this Mac. You can import your existing keys into Moaiy's managed keyring."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "检测到此 Mac 存在已有 GnuPG 目录。您可以将现有密钥导入到 Moaiy 管理的密钥库。"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Encontramos una casa GnuPG existente en esta Mac. Puede importar sus claves existentes al conjunto de claves administrado de Moaiy."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Encontramos uma página inicial do GnuPG existente neste Mac. Você pode importar suas chaves existentes para o chaveiro gerenciado do Moaiy."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "हमें इस Mac पर एक मौजूदा GnuPG होम मिला। आप अपनी मौजूदा चाबियाँ Moaiy की प्रबंधित कीरिंग में आयात कर सकते हैं।"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "لقد عثرنا على منزل GnuPG موجود على جهاز Mac هذا. يمكنك استيراد مفاتيحك الحالية إلى حلقة المفاتيح المُدارة من Moaiy."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Nous avons trouvé une maison GnuPG existante sur ce Mac. Vous pouvez importer vos clés existantes dans le trousseau de clés géré de Moaiy."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wir haben auf diesem Mac ein vorhandenes GnuPG-Heim gefunden. Sie können Ihre vorhandenen Schlüssel in den verwalteten Schlüsselbund von Moaiy importieren."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "この Mac 上に既存の GnuPG ホームが見つかりました。既存のキーを Moaiy の管理対象キーリングにインポートできます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 Mac에서 기존 GnuPG 홈을 찾았습니다. 기존 키를 Moaiy의 관리형 키링으로 가져올 수 있습니다."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Мы нашли существующий дом GnuPG на этом Mac. Вы можете импортировать существующие ключи в управляемую связку ключей Moaiy."
          }
        }
      }
    },
