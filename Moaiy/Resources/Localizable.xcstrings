    "tutorial_encrypt_files_content" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Choose Encrypt in a key menu or drop files onto a key card. Encrypted files use the .gpg extension."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "在密钥菜单中选择加密，或将文件拖到密钥卡片上。加密后文件扩展名为 .gpg。"
          }
        }
      }
    },
