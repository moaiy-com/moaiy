        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "この Mac 上に既存の GnuPG ホームが見つかりました。既存のキーを Moaiy の管理対象キーリングにインポートできます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "이 Mac에서 기존 GnuPG 홈을 찾았습니다. 기존 키를 Moaiy의 관리형 키링으로 가져올 수 있습니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
