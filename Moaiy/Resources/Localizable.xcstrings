    "confirm_delete_key_message" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "هل أنت متأكد أنك تريد حذف المفتاح \"%@\"؟ لا يمكن التراجع عن هذا الإجراء."
          }
