    "notification_expired_keys_body": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You have %lld expired keys. Please review them in Moaiy."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "您有 %lld 个密钥已过期。请在 Moaiy 中查看。"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Tienes claves caducadas %lld. Por favor revísalos en Moaiy."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Você tem chaves expiradas %lld. Por favor, revise-os em Moaiy."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "आपके पास %lld की समय सीमा समाप्त हो गई है। कृपया Moaiy में उनकी समीक्षा करें।"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "لديك مفاتيح %lld منتهية الصلاحية. يرجى مراجعتها في Moaiy."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vous disposez de clés %lld expirées. Veuillez les consulter dans Moaiy."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Sie haben %lld abgelaufene Schlüssel. Bitte überprüfen Sie sie in Moaiy."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%lld の有効期限が切れたキーがあります。 Moaiyでレビューしてください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "%lld 만료된 키가 있습니다. 모아이에서 검토해 보세요."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "У вас есть ключи с истекшим сроком действия %lld. Пожалуйста, просмотрите их в Moaiy."
          }
        }
      }
    },
