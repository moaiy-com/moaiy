    "trust_ultimate_warning": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Ultimate trust should only be set for your own keys"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "终极信任仅应用于您自己的密钥"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La confianza máxima sólo debe establecerse para sus propias claves"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "A confiança final só deve ser definida para suas próprias chaves"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "अंतिम विश्वास केवल आपकी अपनी चाबियों के लिए निर्धारित किया जाना चाहिए"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يجب تعيين الثقة النهائية فقط للمفاتيح الخاصة بك"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La confiance ultime ne doit être définie que pour vos propres clés"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ultimatives Vertrauen sollte nur für Ihre eigenen Schlüssel festgelegt werden"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "最終的な信頼は自分のキーに対してのみ設定する必要があります"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "궁극적인 신뢰는 자신의 키에 대해서만 설정되어야 합니다."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Максимальное доверие должно быть установлено только для ваших собственных ключей."
          }
        }
      }
    },
