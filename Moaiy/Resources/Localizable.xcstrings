    "yubikey_import_description": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Detect an inserted smartcard, fetch OpenPGP shadow stubs, and try to auto-import public keys from the card URL."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "检测已插入智能卡，获取 OpenPGP 存根，并尝试从卡内公钥 URL 自动导入公钥。"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Detecte una tarjeta inteligente insertada, obtenga apéndices ocultos de OpenPGP e intente importar automáticamente claves públicas desde la URL de la tarjeta."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Detecte um smartcard inserido, busque shadow stubs do OpenPGP e tente importar automaticamente as chaves públicas do URL do cartão."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "डाले गए स्मार्टकार्ड का पता लगाएं, ओपनपीजीपी छाया स्टब्स लाएं, और कार्ड यूआरएल से सार्वजनिक कुंजी को स्वचालित रूप से आयात करने का प्रयास करें।"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "اكتشف البطاقة الذكية المُدرجة، واجلب كعب ظل OpenPGP، وحاول استيراد المفاتيح العامة تلقائيًا من عنوان URL للبطاقة."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Détectez une carte à puce insérée, récupérez les talons fantômes OpenPGP et essayez d'importer automatiquement les clés publiques à partir de l'URL de la carte."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Erkennen Sie eine eingelegte Smartcard, rufen Sie OpenPGP-Shadow-Stubs ab und versuchen Sie, öffentliche Schlüssel automatisch von der Karten-URL zu importieren."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "挿入されたスマートカードを検出し、OpenPGP シャドウ スタブを取得し、カード URL から公開キーの自動インポートを試みます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "삽입된 스마트 카드를 감지하고, OpenPGP 섀도우 스텁을 가져오고, 카드 URL에서 공개 키 자동 가져오기를 시도합니다."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Обнаружьте вставленную смарт-карту, получите теневые заглушки OpenPGP и попытайтесь автоматически импортировать открытые ключи из URL-адреса карты."
          }
        }
      }
    },
