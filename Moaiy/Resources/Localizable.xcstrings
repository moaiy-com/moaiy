    "tutorial_what_is_gpg_content" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تحمي GPG بياناتك من خلال تشفير المفتاح العام. شارك مفتاحك العام واحتفظ بسرية مفتاحك الخاص."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "GPG schützt Ihre Daten mit Public-Key-Kryptografie. Teilen Sie Ihren öffentlichen Schlüssel und halten Sie Ihren privaten Schlüssel geheim."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "GPG protects your data with public-key cryptography. Share your public key and keep your private key secret."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "GPG protege sus datos con criptografía de clave pública. Comparta su clave pública y mantenga en secreto su clave privada."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "GPG protège vos données avec une cryptographie à clé publique. Partagez votre clé publique et gardez votre clé privée secrète."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "GPG आपके डेटा को सार्वजनिक-कुंजी क्रिप्टोग्राफी से सुरक्षित रखता है। अपनी सार्वजनिक कुंजी साझा करें और अपनी निजी कुंजी गुप्त रखें।"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "GPG は公開キー暗号化を使用してデータを保護します。公開キーを共有し、秘密キーを秘密にしておきます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "GPG는 공개 키 암호화로 데이터를 보호합니다. 공개 키를 공유하고 개인 키를 비밀로 유지하세요."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O GPG protege seus dados com criptografia de chave pública. Compartilhe sua chave pública e mantenha sua chave privada em segredo."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "GPG защищает ваши данные с помощью криптографии с открытым ключом. Поделитесь своим открытым ключом и сохраните свой закрытый ключ в секрете."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "GPG 通过公钥密码体系保护你的数据。可以分享公钥，但必须妥善保管私钥。"
          }
        }
      }
    },
