    "create_key_empty_passphrase_message" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "سيتم تخزين مفتاحك الخاص دون حماية عبارة المرور. يمكن لأي شخص لديه حق الوصول إلى الملف استخدامه."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ihr privater Schlüssel wird ohne Passwortschutz gespeichert. Jeder mit Dateizugriff kann es verwenden."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Your private key will be stored without passphrase protection. Anyone with file access may use it."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Su clave privada se almacenará sin protección mediante contraseña. Cualquier persona con acceso a archivos puede usarlo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Votre clé privée sera stockée sans protection par phrase secrète. Toute personne ayant accès aux fichiers peut l'utiliser."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "आपकी निजी कुंजी बिना पासफ़्रेज़ सुरक्षा के संग्रहीत की जाएगी। फ़ाइल एक्सेस वाला कोई भी व्यक्ति इसका उपयोग कर सकता है।"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "秘密キーはパスフレーズ保護なしで保存されます。ファイルにアクセスできる人であれば誰でも使用できます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "귀하의 개인 키는 암호 보호 없이 저장됩니다. 파일 액세스 권한이 있는 사람은 누구나 사용할 수 있습니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sua chave privada será armazenada sem proteção por senha. Qualquer pessoa com acesso a arquivos pode usá-lo."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ваш закрытый ключ будет храниться без защиты паролем. Любой, у кого есть доступ к файлам, может использовать его."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "您的私钥将不受密码保护。任何能访问该文件的人都可能使用它。"
          }
        }
      }
    },
