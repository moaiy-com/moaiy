          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nous avons trouvé une maison GnuPG existante sur ce Mac. Vous pouvez importer vos clés existantes dans le trousseau de clés géré de Moaiy."
