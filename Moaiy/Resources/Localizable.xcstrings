    "verify_file_picker_message": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Select the signed file or a signature file (.sig/.asc) to verify"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "选择已签名文件，或选择签名文件（.sig/.asc）进行验证"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Seleccione el archivo firmado o un archivo de firma (.sig/.asc) para verificar"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Selecione o arquivo assinado ou um arquivo de assinatura (.sig/.asc) para verificar"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "सत्यापित करने के लिए हस्ताक्षरित फ़ाइल या हस्ताक्षर फ़ाइल (.sig/.asc) का चयन करें"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "حدد الملف الموقع أو ملف التوقيع (.sig/.asc) للتحقق منه"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Sélectionnez le fichier signé ou un fichier de signature (.sig/.asc) pour vérifier"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wählen Sie die signierte Datei oder eine Signaturdatei (.sig/.asc) zur Überprüfung aus"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "検証する署名付きファイルまたは署名ファイル (.sig/.asc) を選択します"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "서명된 파일 또는 서명 파일(.sig/.asc)을 선택하여 확인하세요."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Выберите подписанный файл или файл подписи (.sig/.asc) для проверки."
          }
        }
      }
