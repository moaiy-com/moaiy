    "tutorial_encrypt_files_content" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "اختر تشفير في قائمة المفاتيح أو قم بإسقاط الملفات على بطاقة المفتاح. تستخدم الملفات المشفرة الامتداد .gpg."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wählen Sie „Verschlüsseln“ in einem Schlüsselmenü oder legen Sie Dateien auf einer Schlüsselkarte ab. Verschlüsselte Dateien verwenden die Erweiterung .gpg."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Choose Encrypt in a key menu or drop files onto a key card. Encrypted files use the .gpg extension."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Elija Cifrar en un menú de clave o suelte archivos en una tarjeta de clave. Los archivos cifrados utilizan la extensión .gpg."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Choisissez Chiffrer dans un menu clé ou déposez des fichiers sur une carte-clé. Les fichiers cryptés utilisent l'extension .gpg."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "कुंजी मेनू में एन्क्रिप्ट करें चुनें या कुंजी कार्ड पर फ़ाइलें छोड़ें। एन्क्रिप्टेड फ़ाइलें .gpg एक्सटेंशन का उपयोग करती हैं।"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "キー メニューで [暗号化] を選択するか、ファイルをキー カードにドロップします。暗号化されたファイルには .gpg 拡張子が使用されます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "키 메뉴에서 암호화를 선택하거나 파일을 키 카드에 넣으세요. 암호화된 파일은 .gpg 확장자를 사용합니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Escolha Criptografar em um menu de chave ou coloque os arquivos em um cartão-chave. Os arquivos criptografados usam a extensão .gpg."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Выберите «Шифровать» в меню ключа или перетащите файлы на карту-ключ. Зашифрованные файлы имеют расширение .gpg."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "在密钥菜单中选择加密，或将文件拖到密钥卡片上。加密后文件扩展名为 .gpg。"
          }
        }
      }
    },
