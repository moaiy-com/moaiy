    "subkey_rotation_guidance_default" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "لأمان أفضل، قم بتدوير مفاتيح التوقيع/المصادقة الفرعية بانتظام واحتفظ بخطة الإبطال جاهزة."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Für bessere Sicherheit sollten Sie Signatur-/Authentifizierungs-Unterschlüssel regelmäßig rotieren und Widerrufswege vorbereiten."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "For better security, rotate signing and authentication subkeys regularly and keep revocation paths ready."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Para mayor seguridad, rote regularmente las subclaves de firma/autenticación y mantenga listo el plan de revocación."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pour une meilleure sécurité, faites tourner régulièrement les sous-clés de signature/authentification et gardez un plan de révocation prêt."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "बेहतर सुरक्षा के लिए, साइनिंग/ऑथेंटिकेशन उप-कुंजियों को नियमित रूप से रोटेट करें और निरस्तीकरण योजना तैयार रखें।"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "安全性向上のため、署名/認証サブキーを定期的にローテーションし、失効手順を事前に準備してください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "보안을 위해 서명/인증 하위 키를 주기적으로 교체하고 폐기 절차를 미리 준비하세요."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Para maior segurança, faça rotação regular das subchaves de assinatura/autenticação e mantenha o plano de revogação pronto."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Для повышения безопасности регулярно ротируйте подключи подписи/аутентификации и заранее готовьте путь отзыва."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "为提升安全性，建议定期轮换签名/认证子密钥，并预先准备吊销方案。"
          }
        }
      }
    },
    "subkey_rotation_guidance_expiring" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ستنتهي صلاحية بعض المفاتيح الفرعية قريبًا. جهّز مفاتيح بديلة مسبقًا."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Einige Unterschlüssel laufen bald ab. Bereiten Sie rechtzeitig Ersatz-Unterschlüssel vor."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Some subkeys are expiring soon. Prepare replacement subkeys in advance."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Algunas subclaves vencerán pronto. Prepare subclaves de reemplazo con antelación."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Certaines sous-clés expirent bientôt. Préparez des sous-clés de remplacement à l’avance."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "कुछ उप-कुंजियाँ जल्द समाप्त होने वाली हैं। पहले से प्रतिस्थापन तैयार करें।"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "一部のサブキーはまもなく期限切れになります。事前に置き換え用サブキーを準備してください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "일부 하위 키가 곧 만료됩니다. 미리 교체 하위 키를 준비하세요."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Algumas subchaves expirarão em breve. Prepare subchaves de substituição com antecedência."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Срок действия некоторых подключей скоро истечёт. Подготовьте замену заранее."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "部分子密钥即将到期。请提前准备替换子密钥。"
          }
        }
      }
    },
    "subkey_rotation_guidance_high_risk" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تم اكتشاف مفاتيح فرعية عالية الخطورة. قم بإبطالها أو استبدالها بأسرع وقت."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Unterschlüssel mit hohem Risiko erkannt. Widerrufen oder ersetzen Sie sie so schnell wie möglich."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "High-risk subkeys detected. Revoke or replace them as soon as possible."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Se detectaron subclaves de alto riesgo. Revóquelas o reemplácelas cuanto antes."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Des sous-clés à haut risque ont été détectées. Révoquez-les ou remplacez-les rapidement."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "उच्च-जोखिम उप-कुंजियाँ मिलीं। इन्हें जल्द से जल्द निरस्त या बदलें।"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "高リスクのサブキーが検出されました。できるだけ早く失効または置き換えを行ってください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "고위험 하위 키가 감지되었습니다. 가능한 한 빨리 폐기하거나 교체하세요."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Subchaves de alto risco detectadas. Revogue ou substitua o quanto antes."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Обнаружены подключи с высоким риском. Как можно скорее отзовите или замените их."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "检测到高风险子密钥。请尽快吊销或替换。"
          }
        }
      }
    },
