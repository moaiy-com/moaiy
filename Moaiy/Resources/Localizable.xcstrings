    "tutorial_backup_keys_content": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Use Backup Manager to create backups and store them in a safe offline location."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "使用备份管理器创建备份，并将其保存在安全的离线位置。"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Utilice Backup Manager para crear copias de seguridad y almacenarlas en una ubicación segura sin conexión."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Use o Backup Manager para criar backups e armazená-los em um local offline seguro."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "बैकअप बनाने और उन्हें सुरक्षित ऑफ़लाइन स्थान पर संग्रहीत करने के लिए बैकअप प्रबंधक का उपयोग करें।"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "استخدم Backup Manager لإنشاء نسخ احتياطية وتخزينها في مكان آمن دون اتصال بالإنترنت."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Utilisez Backup Manager pour créer des sauvegardes et les stocker dans un emplacement hors ligne sécurisé."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Verwenden Sie den Backup Manager, um Backups zu erstellen und diese an einem sicheren Offline-Speicherort zu speichern."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "バックアップ マネージャーを使用してバックアップを作成し、オフラインの安全な場所に保存します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "백업 관리자를 사용하여 백업을 생성하고 안전한 오프라인 위치에 저장하세요."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Используйте Backup Manager для создания резервных копий и хранения их в безопасном автономном месте."
          }
        }
      }
    },
    "tutorial_create_first_key": {
