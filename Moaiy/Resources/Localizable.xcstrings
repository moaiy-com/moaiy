    "key_type_rsa_description": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Most widely compatible, recommended for most users"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "兼容性最广，推荐大多数用户使用"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Más ampliamente compatible, recomendado para la mayoría de los usuarios."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Mais amplamente compatível, recomendado para a maioria dos usuários"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "सर्वाधिक व्यापक रूप से संगत, अधिकांश उपयोगकर्ताओं के लिए अनुशंसित"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "الأكثر توافقًا على نطاق واسع، موصى به لمعظم المستخدمين"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le plus largement compatible, recommandé pour la plupart des utilisateurs"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Am weitesten kompatibel, für die meisten Benutzer empfohlen"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "最も幅広い互換性があり、ほとんどのユーザーに推奨されます"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "가장 널리 호환되며 대부분의 사용자에게 권장됩니다."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Наиболее широко совместим, рекомендуется для большинства пользователей."
          }
        }
      }
    },
