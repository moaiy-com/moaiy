          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Modern und effizient, kleinere Schlüsselgröße bei gleicher Sicherheit"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "最新かつ効率的で、同じセキュリティを備えたより小さなキー サイズ"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "동일한 보안을 유지하면서 현대적이고 효율적이며 더 작은 키 크기"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
