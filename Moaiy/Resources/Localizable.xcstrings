    "tutorial_decrypt_files_content": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Choose Decrypt and provide the key passphrase. Encrypted files are restored to their original names."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "选择解密并输入密钥口令。加密文件会恢复为原始文件名。"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Elija Descifrar y proporcione la frase de contraseña clave. Los archivos cifrados se restauran a sus nombres originales."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Escolha Descriptografar e forneça a senha da chave. Os arquivos criptografados são restaurados aos seus nomes originais."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "डिक्रिप्ट चुनें और कुंजी पासफ़्रेज़ प्रदान करें। एन्क्रिप्टेड फ़ाइलें उनके मूल नामों में पुनर्स्थापित की जाती हैं।"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "اختر فك التشفير وقم بتوفير عبارة المرور الرئيسية. تتم استعادة الملفات المشفرة إلى أسمائها الأصلية."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Choisissez Déchiffrer et fournissez la phrase secrète de la clé. Les fichiers cryptés sont restaurés à leurs noms d'origine."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wählen Sie „Entschlüsseln“ und geben Sie die Schlüsselpassphrase ein. Verschlüsselte Dateien werden unter ihren ursprünglichen Namen wiederhergestellt."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "[復号化] を選択し、キーのパスフレーズを指定します。暗号化されたファイルは元の名前に復元されます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Decrypt를 선택하고 키 암호를 제공합니다. 암호화된 파일은 원래 이름으로 복원됩니다."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Выберите «Расшифровать» и укажите ключевую фразу-пароль. Зашифрованным файлам восстанавливаются их первоначальные имена."
          }
        }
      }
    },
