    "tutorial_public_private_keys_content": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Public keys encrypt or verify. Private keys decrypt or sign. Never share your private key."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "公钥用于加密或验证，私钥用于解密或签名。请勿分享你的私钥。"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Las claves públicas cifran o verifican. Las claves privadas se descifran o firman. Nunca compartas tu clave privada."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "As chaves públicas criptografam ou verificam. As chaves privadas são descriptografadas ou assinadas. Nunca compartilhe sua chave privada."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "सार्वजनिक कुंजियाँ एन्क्रिप्ट या सत्यापित करें। निजी कुंजियाँ डिक्रिप्ट या हस्ताक्षर करती हैं। अपनी निजी कुंजी कभी साझा न करें."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تشفير المفاتيح العامة أو التحقق منها. فك تشفير المفاتيح الخاصة أو التوقيع عليها. لا تشارك مفتاحك الخاص أبدًا."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les clés publiques chiffrent ou vérifient. Les clés privées décryptent ou signent. Ne partagez jamais votre clé privée."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Öffentliche Schlüssel verschlüsseln oder verifizieren. Private Schlüssel entschlüsseln oder signieren. Geben Sie niemals Ihren privaten Schlüssel weiter."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "公開鍵は暗号化または検証します。秘密キーは復号化または署名します。秘密キーを決して共有しないでください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "공개 키는 암호화하거나 확인합니다. 개인 키는 암호를 해독하거나 서명합니다. 개인 키를 절대 공유하지 마세요."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Открытые ключи шифруют или проверяют. Закрытые ключи расшифровывают или подписывают. Никогда не делитесь своим секретным ключом."
          }
        }
      }
    },
