    "key_type_ecc_description": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Modern and efficient, smaller key size with same security"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "现代高效，更小的密钥尺寸但同等安全性"
