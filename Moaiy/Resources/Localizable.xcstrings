    "edit_expiration_description": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Change when this key expires or make it never expire"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "更改此密钥的过期时间或设置为永不过期"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Cambiar cuándo caduca esta clave o hacer que nunca caduque"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Altere quando esta chave expira ou faça com que ela nunca expire"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "इस कुंजी के समाप्त होने पर बदलें या इसे कभी समाप्त न होने दें"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "قم بتغيير موعد انتهاء صلاحية هذا المفتاح أو اجعله لا تنتهي صلاحيته أبدًا"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Changer la date d'expiration de cette clé ou la faire en sorte qu'elle n'expire jamais"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ändern Sie, wann dieser Schlüssel abläuft, oder legen Sie fest, dass er niemals abläuft"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このキーの有効期限が切れるタイミングを変更するか、有効期限が切れないようにする"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 키가 만료되는 시기를 변경하거나 만료되지 않도록 설정"
